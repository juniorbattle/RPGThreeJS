{
  "name": "rpg-threejs",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "blender:check": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/blender/blender.ps1 --background --python tools/blender/check_environment.py",
    "blender:version": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/blender/blender.ps1 --version",
    "blender:forest": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/blender/blender.ps1 --background --python tools/blender/build_forest_kit.py"
  },
  "dependencies": {
    "@fontsource/cinzel": "5.1.1",
    "@fontsource/inter": "5.1.1",
    "@fontsource/vt323": "5.1.1",
    "three": "0.160.0",
    "zod": "3.24.2"
  },
  "devDependencies": {
    "@types/three": "0.160.0",
    "happy-dom": "^20.11.0",
    "typescript": "5.7.3",
    "vite": "6.1.0",
    "vitest": "3.0.7"
  }
}
